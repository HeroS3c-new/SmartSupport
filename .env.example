# MaeSkimmer Configuration Template
# Copy this file to .env and fill in the values

# General
NODE_ENV=development
PORT=80
HTTPS_PORT=443
SESSION_SECRET=your_super_secret_session_key

# Google OAuth (Gmail API)
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
REDIRECT_URI=http://localhost/oauth2callback

# Redmine Integration
REDMINE_API_KEY=your_redmine_api_key
REDMINE_PROJECT_ID=7291
REDMINE_URL=https://projects.maestrale.it/issues.json

# LDAP Authentication
LDAP_URL=ldap://your_ldap_server
LDAP_BASE_DN=DC=your,DC=domain
LDAP_DOMAIN=your.domain

# SMTP Configuration (for notifications)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# ML Prediction Server
# The Python server runs by default on port 5001
CLASSIFICATION_API_URL=https://localhost:5001/classify
